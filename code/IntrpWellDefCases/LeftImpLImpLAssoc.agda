  {f : ќФвВА ++ E вИЈ ќФвВБ вКҐ A} {g : ќЫвВА ++ B вИЈ ќЫвВБ вКҐ C}
  вЖТ mip [] (ќЫвВА ++ B вЗР A вИЈ ќФвВА) (E вИЈ ќФвВБ ++ ќЫвВБ)
      (вЗРL {ќЫвВА} {ќФвВА ++ E вИЈ ќФвВБ} {ќЫвВБ} f g) refl
