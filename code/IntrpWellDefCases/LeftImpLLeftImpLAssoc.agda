  with ╬ЏРѓЂ
... | [] rewrite ++?-injРѓЂ [] (╬ЊРѓЂ ++ B' Рѕи []) ╬ъ |
                 cases++-injРѓЂ ╬ЊРѓЂ (╬Е''' ++ F Рѕи ╬Е'''') [] (B' РЄљ A') |
                 cases++-injРѓЂ ╬ЊРѓЂ ╬Е''' (F Рѕи ╬Е'''') (B' РЄљ A') |
