        ╬ъ
        {f = MIP.h Fm} {g = MIP.h Gm}
        {h =
          РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D Fm Рѕи []}
            {╬Џ = MIP.D Gm Рѕи ╬ъ}
