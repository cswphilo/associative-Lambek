          {╬ЏРѓЂ = []}
          {A = A} {A' = A'} {B = B} {B' = B'}
          {f = f} {g = MIP.g H} {h = MIP.h K})))
mipРЅЌРЄљLРЄљL-assoc ╬Њ (E Рѕи .(╬Е' ++ B РЄљ A Рѕи ╬Е)) .(F Рѕи ╬Е'' ++ ╬ъ)
  {╬ЊРѓЂ} {.(╬Њ ++ E Рѕи ╬Е')} {.(╬Е''' ++ F' Рѕи ╬Е'''')} {╬ЏРѓЂ} {╬ъ}
  {A} {B} {A'} {B'} {C} {f} {g} {h} eq
