module IntrpWellDefCases.LeftImpLLeftImpLAssoc where

open import IntrpWellDefCases.Base

РіЌR-assoc-eqh : Рѕђ {╬ћРѓђ ╬ћРѓЂ ╬ћРѓѓ DG DH DK}
  {hG : ╬ћРѓђ Ріб DG} {hH : ╬ћРѓЂ Ріб DH} {hK : ╬ћРѓѓ Ріб DK}
  Рєњ cut [] (РіЌR (РіЌR hG hH) hK)
      (РіЌL {[]} (РіЌL {[]} (РіЌR ax (РіЌR ax ax)))) refl
      РЅЌ РіЌR hG (РіЌR hH hK)
РіЌR-assoc-eqh = refl

РЄљLРЄљL~РЄљРіЌ : Рѕђ {╬Њ ╬ЊРѓђ ╬ЊРѓЂ ╬ћРѓђ ╬ћРѓЂ ╬ћРѓѓ ╬Џ A B A' B' C}
  Рєњ (G : MIP ╬ЊРѓЂ ╬ћРѓђ [] A')
  Рєњ (H : MIP (╬ЊРѓђ ++ B' Рѕи []) ╬ћРѓЂ [] A)
  Рєњ (K : MIP (╬Њ ++ B Рѕи []) ╬ћРѓѓ ╬Џ C)
  Рєњ РЄљL~РіЌ' {╬ЊРѓђ = ╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ} {╬ЊРѓЂ = ╬ЊРѓЂ}
      G (РЄљL~РіЌ' {╬ЊРѓђ = ╬Њ} {╬ЊРѓЂ = ╬ЊРѓђ ++ B' Рѕи []} H K)
      ~ РЄљL~РіЌ' {╬ЊРѓђ = ╬Њ} {╬ЊРѓЂ = ╬ЊРѓђ ++ B' РЄљ A' Рѕи ╬ЊРѓЂ}
          (РЄљL~РіЌ' {╬ЊРѓђ = ╬ЊРѓђ} {╬ЊРѓЂ = ╬ЊРѓЂ} G H) K
РЄљLРЄљL~РЄљРіЌ {╬Њ} {╬ЊРѓђ} {╬ЊРѓЂ} {╬ћРѓђ} {╬ћРѓЂ} {╬ћРѓѓ} {╬Џ} {A} {B} {A'} {B'} {C}
  (intrp DG gG hG) (intrp DH gH hH) (intrp DK gK hK) =
  let ╬Њo = ╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ ++ B' РЄљ A' Рѕи ╬ЊРѓЂ
      q : DH Рѕи DK Рѕи [] Ріб DH РіЌ DK
      q = РіЌR ax ax
      r : DG Рѕи DH Рѕи DK Рѕи [] Ріб DG РіЌ (DH РіЌ DK)
      r = РіЌR ax q
      s : DG РіЌ DH Рѕи DK Рѕи [] Ріб DG РіЌ (DH РіЌ DK)
      s = РіЌL {[]} r
      t : (DG РіЌ DH) РіЌ DK Рѕи [] Ріб DG РіЌ (DH РіЌ DK)
      t = РіЌL {[]} s
      body : ╬Њo ++ DG Рѕи DH РіЌ DK Рѕи ╬Џ Ріб C
      body =
        РЄљL {╬Њ = ╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ} {╬ћ = ╬ЊРѓЂ ++ DG Рѕи []}
          {╬Џ = DH РіЌ DK Рѕи ╬Џ} {A = A'} {B = B'} {C = C}
          gG
          (РіЌL {╬Њ = ╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ ++ B' Рѕи []} {╬ћ = ╬Џ}
            {A = DH} {B = DK} {C = C}
            (РЄљL {╬Њ = ╬Њ} {╬ћ = ╬ЊРѓђ ++ B' Рѕи DH Рѕи []} {╬Џ = DK Рѕи ╬Џ}
              {A = A} {B = B} {C = C}
              gH gK))
      eqInner :
        РЄљL {╬Њ = ╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ} {╬ћ = ╬ЊРѓЂ ++ DG Рѕи []}
          {╬Џ = DH Рѕи DK Рѕи ╬Џ} {A = A'} {B = B'} {C = C}
          gG
          (РЄљL {╬Њ = ╬Њ} {╬ћ = ╬ЊРѓђ ++ B' Рѕи DH Рѕи []} {╬Џ = DK Рѕи ╬Џ}
            {A = A} {B = B} {C = C}
            gH gK)
        РЅЌ cut (╬Њo ++ DG Рѕи []) q body refl
      eqInner =
        (РЄљL {╬Њ = ╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ} {╬ћ = ╬ЊРѓЂ ++ DG Рѕи []}
          {╬Џ = DH Рѕи DK Рѕи ╬Џ} {A = A'} {B = B'} {C = C}
          refl
          ((~ cutaxA-left (╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ ++ B' Рѕи [])
              (РЄљL gH gK) refl)
           Рѕў
           (cut-congРѓѓ (╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ ++ B' Рѕи []) refl
             (~ cutaxA-left (╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ ++ B' Рѕи DH Рѕи [])
               (РЄљL gH gK) refl)
           Рѕў
           РЅАtoРЅЌ (cutРіЌRРіЌLcases++ (╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ ++ B' Рѕи []) ╬Џ
             {f = ax} {g = ax} {h = РЄљL gH gK}))))
        Рѕў
        (~ (РЅАtoРЅЌ (cutРЄљL-cases++-commРѓЂ (╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ)
          {╬ЊРѓЂ = []} {╬ћ = ╬ЊРѓЂ ++ DG Рѕи []} {╬Џ = ╬Џ}
          {f = q} {g = gG}
          {h = РіЌL {╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ ++ B' Рѕи []} {╬Џ} {DH} {DK}
            (РЄљL {╬Њ = ╬Њ} {╬ћ = ╬ЊРѓђ ++ B' Рѕи DH Рѕи []} {╬Џ = DK Рѕи ╬Џ}
              gH gK)})))
      lhs = РЄљL~РіЌ' {╬ЊРѓђ = ╬Њ ++ B РЄљ A Рѕи ╬ЊРѓђ} {╬ЊРѓЂ = ╬ЊРѓЂ}
        (intrp DG gG hG)
        (РЄљL~РіЌ' {╬ЊРѓђ = ╬Њ} {╬ЊРѓЂ = ╬ЊРѓђ ++ B' Рѕи []}
          (intrp DH gH hH) (intrp DK gK hK))
      rhs = РЄљL~РіЌ' {╬ЊРѓђ = ╬Њ} {╬ЊРѓЂ = ╬ЊРѓђ ++ B' РЄљ A' Рѕи ╬ЊРѓЂ}
        (РЄљL~РіЌ' {╬ЊРѓђ = ╬ЊРѓђ} {╬ЊРѓЂ = ╬ЊРѓЂ}
          (intrp DG gG hG) (intrp DH gH hH))
        (intrp DK gK hK)
      eqg : MIP.g rhs РЅЌ cut ╬Њo t (MIP.g lhs) refl
      eqg =
        РіЌL {╬Њo}
          ((~ (РіЌLРЄљL-assoc {╬Њ = ╬Њ} {╬ћРѓђ = ╬ЊРѓђ ++ B' РЄљ A' Рѕи ╬ЊРѓЂ}
                {╬ћРѓЂ = []} {╬Џ = DK Рѕи ╬Џ}))
          Рѕў
          (РіЌL {╬Њo}
            (~ (РЄљLРЄљL-assoc {╬ЊРѓђ = ╬ЊРѓђ} {╬ЊРѓЂ = ╬Њ}
              {╬ћ = ╬ЊРѓЂ ++ DG Рѕи []} {╬ЏРѓђ = DH Рѕи []} {╬ЏРѓЂ = DK Рѕи ╬Џ}
              {A = A} {A' = A'} {B = B} {B' = B'}
              {f = gG} {g = gH} {h = gK}))
          Рѕў
          (РіЌL {╬Њo} eqInner
          Рѕў
          (РіЌL {╬Њo}
            (((~ cutaxA-left ╬Њo
                (cut (╬Њo ++ DG Рѕи []) q body refl) refl)
              Рѕў
              РЅАtoРЅЌ (cutРіЌRРіЌLcases++ ╬Њo ╬Џ
                {f = ax} {g = q} {h = body})))
          Рѕў
          (~ cutРіЌLРЅЌ ╬Њo [] (DK Рѕи []) r
            (РіЌL {╬Њo} {╬Џ} {DG} {DH РіЌ DK} body) refl)))))
        Рѕў (~ (cutРіЌLРЅЌ ╬Њo [] [] s (MIP.g lhs) refl))
      eqh : cut [] (MIP.h rhs) t refl РЅЌ MIP.h lhs
      eqh = РіЌR-assoc-eqh
  in РєюРѕи {n = lhs} {n' = rhs} (t , eqg , eqh) refl

mipРЅЌРЄљLРЄљL-assoc : Рѕђ ╬Њ ╬ћ ╬Џ
  {╬ЊРѓђ ╬ЊРѓЂ ╬ћРѓђ ╬ЏРѓђ ╬ЏРѓЂ : Cxt} {A B A' B' C : Fma}
  {f : ╬ћРѓђ Ріб A'} {g : ╬ЊРѓђ ++ B' Рѕи ╬ЏРѓђ Ріб A} {h : ╬ЊРѓЂ ++ B Рѕи ╬ЏРѓЂ Ріб C}
  Рєњ (eq : ╬ЊРѓЂ ++ B РЄљ A Рѕи ╬ЊРѓђ ++ B' РЄљ A' Рѕи ╬ћРѓђ ++ ╬ЏРѓђ ++ ╬ЏРѓЂ РЅА ╬Њ ++ ╬ћ ++ ╬Џ)
  Рєњ MIPРЅЌ ╬Њ ╬ћ ╬Џ C
      (mip ╬Њ ╬ћ ╬Џ (РЄљL {╬ЊРѓЂ ++ B РЄљ A Рѕи ╬ЊРѓђ} {╬ћРѓђ} {╬ЏРѓђ ++ ╬ЏРѓЂ} f (РЄљL {╬ЊРѓЂ} {╬ЊРѓђ ++ B' Рѕи ╬ЏРѓђ} {╬ЏРѓЂ} g h)) eq)
      (mip ╬Њ ╬ћ ╬Џ (РЄљL {╬ЊРѓЂ} {╬ЊРѓђ ++ B' РЄљ A' Рѕи ╬ћРѓђ ++ ╬ЏРѓђ} {╬ЏРѓЂ} (РЄљL {╬ЊРѓђ} {╬ћРѓђ} {╬ЏРѓђ} f g) h) eq)
mipРЅЌРЄљLРЄљL-assoc ╬Њ [] ╬Џ eq = mip[]РЅЌ ╬Њ ╬Џ eq РЄљLРЄљL-assoc
mipРЅЌРЄљLРЄљL-assoc ╬Њ (E Рѕи ╬ћ) ╬Џ {╬ЊРѓЂ} {╬ћРѓђ} {╬ћРѓЂ} {╬ЏРѓЂ} {╬ъ} {A} {B} {A'} {B'} eq 
  with cases++ ╬ћРѓђ (╬Њ ++ E Рѕи ╬ћ) (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ ╬ЏРѓЂ ++ ╬ъ) ╬Џ
   (sym eq)
... | injРѓЂ (╬Е , eq1 , eq2) 
  with cases++ ╬ћРѓђ ╬Њ ╬Е (E Рѕи ╬ћ) eq1
... | injРѓЂ (╬Е' , refl , refl) 
  with cases++ ╬Е' (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) (╬ћ ++ ╬Џ) (╬ЏРѓЂ ++ ╬ъ) eq2
... | injРѓЂ (╬Е'' , eq3 , eq4) 
  with cases++ ╬Е' ╬ЊРѓЂ ╬Е'' (B' РЄљ A' Рѕи ╬ћРѓЂ) eq3
mipРЅЌРЄљLРЄљL-assoc .(╬ћРѓђ ++ B РЄљ A Рѕи ╬Е') (E Рѕи ╬ћ) ╬Џ {╬ЊРѓЂ} {╬ћРѓђ} {╬ћРѓЂ} {╬ЏРѓЂ} {╬ъ} {A} {B} {A'} {B'} eq | injРѓЂ (.(╬Е' ++ E Рѕи ╬ћ) , eq1 , eq2) | injРѓЂ (╬Е' , refl , refl) | injРѓЂ (╬Е'' , refl , eq4) | injРѓЂ (╬Е''' , refl , refl) 
  with ++? ╬Е''' ╬ћ (B' РЄљ A' Рѕи ╬ћРѓЂ ++ ╬ЏРѓЂ ++ ╬ъ) ╬Џ eq4
mipРЅЌРЄљLРЄљL-assoc .(╬ћРѓђ ++ B РЄљ A Рѕи ╬Е') (E Рѕи ╬ћ) ╬Џ {.(╬Е' ++ E Рѕи ╬Е''')} {╬ћРѓђ} {╬ћРѓЂ} {╬ЏРѓЂ} {╬ъ} {A} {B} {A'} {B'} refl | injРѓЂ (.(╬Е' ++ E Рѕи ╬ћ) , refl , refl) | injРѓЂ (╬Е' , refl , refl) | injРѓЂ (.(╬Е''' ++ B' РЄљ A' Рѕи ╬ћРѓЂ) , refl , refl) | injРѓЂ (╬Е''' , refl , refl) | injРѓЂ ([] , refl , refl)
  rewrite cases++-injРѓѓ [] (╬ћРѓђ ++ B РЄљ A Рѕи ╬Е' ++ E Рѕи ╬Е''') (╬ћРѓЂ ++ ╬ЏРѓЂ ++ ╬ъ) (B' РЄљ A') |
          ++?-injРѓѓ (╬Е' ++ E Рѕи ╬Е''') (╬ћРѓЂ ++ ╬ЏРѓЂ) ╬ъ (B' РЄљ A') |
          cases++-injРѓЂ ╬ћРѓђ (╬Е' ++ E Рѕи ╬Е''') (B' Рѕи ╬ЏРѓЂ ++ ╬ъ) (B РЄљ A) |
          cases++-injРѓѓ [] (╬Е' ++ E Рѕи ╬Е''') (╬ћРѓЂ ++ ╬ЏРѓЂ) (B' РЄљ A') |
          cases++-injРѓЂ ╬ћРѓђ ╬Е' (E Рѕи ╬Е''') (B РЄљ A) |
          ++?-injРѓѓ (╬Е' ++ E Рѕи ╬Е''') ╬ЏРѓЂ ╬ъ B' =
  intrpРЅЌ
    (g~
      (РЄљLРЄљL-assoc {╬ЊРѓђ = ╬Е' ++ _ Рѕи []} {╬ЊРѓЂ = ╬ћРѓђ} {╬ћ = ╬ћРѓЂ}
        {╬ЏРѓђ = ╬ЏРѓЂ} {╬ЏРѓЂ = ╬ъ}))
mipРЅЌРЄљLРЄљL-assoc .(╬ћРѓђ ++ B РЄљ A Рѕи ╬Е') (E Рѕи ╬ћ) ╬Џ {.(╬Е' ++ E Рѕи ╬Е''')} {╬ћРѓђ} {╬ћРѓЂ} {╬ЏРѓЂ} {╬ъ} {A} {B} {A'} {B'} refl | injРѓЂ (.(╬Е' ++ E Рѕи ╬ћ) , refl , refl) | injРѓЂ (╬Е' , refl , refl) | injРѓЂ (.(╬Е''' ++ B' РЄљ A' Рѕи ╬ћРѓЂ) , refl , refl) | injРѓЂ (╬Е''' , refl , refl) | injРѓЂ (x Рѕи ╬ъ' , refl , refl)
  rewrite cases++-injРѓѓ (x Рѕи ╬ъ') (╬ћРѓђ ++ B РЄљ A Рѕи ╬Е' ++ E Рѕи ╬ћ) (╬ћРѓЂ ++ ╬ЏРѓЂ ++ ╬ъ) (B' РЄљ A') |
          ++?-injРѓѓ (╬Е' ++ E Рѕи ╬ћ) (╬ъ' ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ ╬ЏРѓЂ) ╬ъ x |
          cases++-injРѓЂ ╬ћРѓђ (╬Е' ++ E Рѕи ╬ћ) (x Рѕи ╬ъ' ++ B' Рѕи ╬ЏРѓЂ ++ ╬ъ) (B РЄљ A) |
          cases++-injРѓѓ (x Рѕи ╬ъ') (╬Е' ++ E Рѕи ╬ћ) (╬ћРѓЂ ++ ╬ЏРѓЂ) (B' РЄљ A') |
          cases++-injРѓЂ ╬ћРѓђ ╬Е' (E Рѕи ╬ћ) (B РЄљ A) |
          ++?-injРѓѓ (╬Е' ++ E Рѕи ╬ћ) (╬ъ' ++ B' Рѕи ╬ЏРѓЂ) ╬ъ x =
  intrpРЅЌ
    (g~
      (РЄљLРЄљL-assoc {╬ЊРѓђ = ╬Е' ++ _ Рѕи x Рѕи ╬ъ'} {╬ЊРѓЂ = ╬ћРѓђ} {╬ћ = ╬ћРѓЂ}
        {╬ЏРѓђ = ╬ЏРѓЂ} {╬ЏРѓЂ = ╬ъ}))
mipРЅЌРЄљLРЄљL-assoc .(╬ћРѓђ ++ B РЄљ A Рѕи ╬Е') (E Рѕи ╬ћ) ╬Џ {╬ЊРѓЂ} {╬ћРѓђ} {╬ћРѓЂ} {╬ЏРѓЂ} {╬ъ} {A} {B} {A'} {B'} eq | injРѓЂ (.(╬Е' ++ E Рѕи ╬ћ) , eq1 , eq2) | injРѓЂ (╬Е' , refl , refl) | injРѓЂ (╬Е'' , refl , eq4) | injРѓЂ (╬Е''' , refl , refl)  | injРѓѓ (F , ╬ъ' , refl , eq6) 
  with ++? ╬ъ' ╬ћРѓЂ ╬Џ (╬ЏРѓЂ ++ ╬ъ) (injРѕи eq6 .projРѓѓ)
... | injРѓЂ (╬ъ'' , eq7 , refl) 
  with ++? ╬ъ'' ╬ЏРѓЂ ╬Џ ╬ъ eq7
mipРЅЌРЄљLРЄљL-assoc .(╬ћРѓђ ++ B РЄљ A Рѕи ╬Е') (E Рѕи .(╬Е''' ++ F Рѕи ╬ћРѓЂ ++ ╬ъ'')) ╬Џ {.(╬Е' ++ E Рѕи ╬Е''')} {╬ћРѓђ} {╬ћРѓЂ} {╬ЏРѓЂ} {╬ъ} {A} {B} {A'} {B'} refl | injРѓЂ (.(╬Е' ++ E Рѕи ╬Е''' ++ F Рѕи ╬ћРѓЂ ++ ╬ъ'') , refl , refl) | injРѓЂ (╬Е' , refl , refl) | injРѓЂ (.(╬Е''' ++ B' РЄљ A' Рѕи ╬ћРѓЂ) , refl , refl) | injРѓЂ (╬Е''' , refl , refl) | injРѓѓ (F , .(╬ћРѓЂ ++ ╬ъ'') , refl , refl) | injРѓЂ (╬ъ'' , eq7 , refl) | injРѓЂ (╬ў , refl , refl)
  rewrite cases++-injРѓЂ (╬ћРѓђ ++ B РЄљ A Рѕи ╬Е' ++ E Рѕи ╬Е''') (╬ћРѓЂ ++ ╬ЏРѓЂ ++ ╬ў) ╬Џ (B' РЄљ A') |
          ++?-injРѓЂ ╬ў (╬Е' ++ E Рѕи ╬Е''' ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ ╬ЏРѓЂ) ╬Џ |
          cases++-injРѓѓ (E Рѕи ╬Е''') (╬ћРѓђ ++ B РЄљ A Рѕи ╬Е') (╬ћРѓЂ ++ ╬ЏРѓЂ ++ ╬ў) (B' РЄљ A') |
          ++?-injРѓЂ (E Рѕи ╬Е''' ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ ╬ЏРѓЂ) ╬Е' ╬ў |
          ++?-injРѓЂ (╬ЏРѓЂ ++ ╬ў) ╬ћРѓЂ ╬Џ |
          cases++-injРѓЂ (╬Е' ++ E Рѕи ╬Е''') (╬ћРѓЂ ++ ╬ЏРѓЂ) [] (B' РЄљ A') |
          cases++-injРѓЂ ╬ћРѓђ (╬Е' ++ E Рѕи ╬Е''' ++ B' Рѕи ╬ЏРѓЂ ++ ╬ў) ╬Џ (B РЄљ A) |
          cases++-injРѓЂ ╬ћРѓђ ╬Е' (E Рѕи ╬Е''' ++ B' Рѕи ╬ЏРѓЂ ++ ╬ў) (B РЄљ A) |
          ++?-injРѓЂ ╬ў (╬Е' ++ E Рѕи ╬Е''' ++ B' Рѕи ╬ЏРѓЂ) ╬Џ |
          ++?-injРѓЂ (E Рѕи ╬Е''' ++ B' Рѕи ╬ЏРѓЂ) ╬Е' ╬ў |
          cases++-injРѓѓ (E Рѕи ╬Е''') ╬Е' (╬ћРѓЂ ++ ╬ЏРѓЂ) (B' РЄљ A') |
