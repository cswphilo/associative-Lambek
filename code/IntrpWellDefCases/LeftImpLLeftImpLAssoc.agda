        _~_ {╬Њ = ╬Њo} {╬ћ = F Рѕи ╬Е''''} {╬Џ = []} {C = A}
          (intrp (MIP.D Fm РіЌ MIP.D H)
            (РіЌL {╬Њo} {[]} body)
            (РіЌR (MIP.h Fm) (MIP.h H)))
