  let Fm = mip ╬Е''' (F Рѕи ╬Е'''') [] f refl
      H = mip (╬ЊРѓЂ ++ B' Рѕи []) [] [] g refl
      K = mip ╬Њ (E Рѕи ╬Е' ++ B Рѕи []) ╬ъ h refl
