            {f = MIP.h H} {g = РіЌR IR ax} {h = MIP.g K}))))
          Рѕў
          cut-congРѓѓ (╬Њ ++ MIP.D K РЄљ (I РіЌ MIP.D H) Рѕи []) refl
            (~ ((cutРЄљLРЅЌ ╬Њ (РіЌR IR ax) ax (MIP.g K) refl)
              Рѕў РЄљL refl (cutaxA-left ╬Њ (MIP.g K) refl))))
        Рѕў (~ (РЅАtoРЅЌ (cutРЄљRРЄљLcases++ ╬Њ ╬ъ (F Рѕи ╬Е'')
          {╬ћ = MIP.D K РЄљ (I РіЌ MIP.D H) Рѕи []}
          {f = body} {g = MIP.h H} {h = MIP.g K})))
      stepFg :
        cut (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) (РіЌR IR ax) fgTensor refl
        РЅЌ fgPlain
      stepFg =
        (((~ (РЅАtoРЅЌ (cutРіЌRРіЌLcases++ (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) []
          {f = IR} {g = ax} {h = fgI})))
          Рѕў
          cut-congРѓѓ (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) refl
            (cutaxA-left (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I Рѕи []) fgI refl))
          Рѕў
          РЅАtoРЅЌ (cutРЄљL-cases++РѓЂ ╬ћРѓЂ ╬ЊРѓЂ {╬Џ = []}
            {╬ЏРѓЂ = MIP.D H Рѕи []}
            {f = IR} {g = IL {╬Њ = ╬ћРѓЂ} {╬ћ = []} f} {h = MIP.g H}))
        Рѕў РЄљL (cutIRIL ╬ћРѓЂ [] {g = f}) refl
      stepBody :
        cut (E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ)
          (РіЌR IR ax) rhsBody refl
        РЅЌ assocBody
      stepBody =
        РЅАtoРЅЌ (cutРЄљL-cases++РѓЂ (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) (E Рѕи ╬Е')
          {╬Џ = []} {╬ЏРѓЂ = []}
          {f = РіЌR IR ax} {g = fgTensor} {h = MIP.h K})
        Рѕў РЄљL stepFg refl
      bodyCut :
        cut [] rhsH body refl РЅЌ assocBody
      bodyCut =
        (РЅАtoРЅЌ (cutРЄљRРЄљLcases++ [] [] (MIP.D H Рѕи [])
          {╬ћ = E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ}
          {f = rhsBody} {g = РіЌR IR ax} {h = ax})
        Рѕў
        cut-congРѓѓ (E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) refl
          (cutaxA-right rhsBody))
        Рѕў stepBody
      eqh :
        cut [] rhsH t refl РЅЌ lhsH
      eqh =
        (РЄљR bodyCut
        Рѕў
        РЄљR (~ (РЄљLРЄљL-assoc {╬ЊРѓђ = ╬ЊРѓЂ} {╬ЊРѓЂ = E Рѕи ╬Е'}
          {╬ћ = ╬ћРѓЂ} {╬ЏРѓђ = MIP.D H Рѕи []} {╬ЏРѓЂ = []}
          {A = A} {A' = A'} {B = B} {B' = B'}
          {f = f} {g = MIP.g H} {h = MIP.h K})))
        Рѕў
        (~ (РЄљLРЄљR {╬Њ = E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ} {╬Џ = []}
          {A = A'} {B = B'} {A' = MIP.D H} {B' = MIP.D K}
          {f = f} {g = innerH}))
  in intrpРЅЌ (РєюРѕи (t , eqg , eqh) refl)
... | L Рѕи ╬Е''''' rewrite ++?-injРѓѓ ╬ћРѓЂ ╬Е''''' (F Рѕи ╬Е'') L |
