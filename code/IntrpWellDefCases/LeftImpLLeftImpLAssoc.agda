          {A = MIP.D H}
          body
      lhsG = РЄљL {╬Њ = ╬Њ} {╬ћ = F Рѕи ╬Е'} {╬Џ = ╬ъ}
        (MIP.h H) (MIP.g K)
      rhsG = РЄљL {╬Њ = ╬Њ} {╬ћ = F Рѕи ╬Е'} {╬Џ = ╬ъ}
        (РіЌR IR (MIP.h H)) (MIP.g K)
      midG :
        ╬Њ ++ MIP.D K РЄљ (I РіЌ MIP.D H) Рѕи MIP.D H Рѕи ╬ъ Ріб C
      midG = РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D H Рѕи []} {╬Џ = ╬ъ}
        {A = I РіЌ MIP.D H} {B = MIP.D K}
        (РіЌR IR ax) (MIP.g K)
      innerH : B РЄљ A Рѕи ╬ЊРѓЂ ++ B' Рѕи MIP.D H Рѕи [] Ріб MIP.D K
      innerH =
        РЄљL {╬Њ = []} {╬ћ = ╬ЊРѓЂ ++ B' Рѕи MIP.D H Рѕи []} {╬Џ = []}
          {A = A} {B = B}
          (MIP.g H) (MIP.h K)
      fgI : ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I Рѕи MIP.D H Рѕи [] Ріб A
      fgI =
        РЄљL {╬Њ = ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ ++ I Рѕи []} {╬Џ = MIP.D H Рѕи []}
          (IL {╬Њ = ╬ћРѓЂ} {╬ћ = []} f) (MIP.g H)
      fgTensor : ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I РіЌ MIP.D H Рѕи [] Ріб A
      fgTensor = РіЌL {╬Њ = ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ} {╬ћ = []} fgI
      fgPlain : ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ MIP.D H Рѕи [] Ріб A
      fgPlain =
        РЄљL {╬Њ = ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ} {╬Џ = MIP.D H Рѕи []}
          f (MIP.g H)
      rhsBody : B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I РіЌ MIP.D H Рѕи [] Ріб MIP.D K
      rhsBody =
        РЄљL {╬Њ = []}
          {╬ћ = ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I РіЌ MIP.D H Рѕи []}
          {╬Џ = []} {A = A} {B = B}
          fgTensor (MIP.h K)
      assocBody : B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ MIP.D H Рѕи [] Ріб MIP.D K
      assocBody =
        РЄљL {╬Њ = []}
          {╬ћ = ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ MIP.D H Рѕи []}
          {╬Џ = []} {A = A} {B = B}
          fgPlain (MIP.h K)
      lhsH =
        РЄљL {╬Њ = B РЄљ A Рѕи ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ} {╬Џ = []}
          f
          (РЄљR {╬Њ = B РЄљ A Рѕи ╬ЊРѓЂ ++ B' Рѕи []}
            {A = MIP.D H}
            innerH)
      rhsH =
        РЄљR {╬Њ = B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ}
          {A = I РіЌ MIP.D H}
          rhsBody
      eqg :
        rhsG РЅЌ cut ╬Њ t lhsG refl
      eqg =
        (((РЄљL (~ (РіЌR refl (cutaxA-right (MIP.h H)))) refl)
          Рѕў (~ (РЅАtoРЅЌ (cutРЄљL-cases++РѓЂ [] ╬Њ {╬Џ = []} {╬ЏРѓЂ = ╬ъ}
            {f = MIP.h H} {g = РіЌR IR ax} {h = MIP.g K}))))
          Рѕў
          cut-congРѓѓ (╬Њ ++ MIP.D K РЄљ (I РіЌ MIP.D H) Рѕи []) refl
            (~ ((cutРЄљLРЅЌ ╬Њ (РіЌR IR ax) ax (MIP.g K) refl)
              Рѕў РЄљL refl (cutaxA-left ╬Њ (MIP.g K) refl))))
        Рѕў (~ (РЅАtoРЅЌ (cutРЄљRРЄљLcases++ ╬Њ ╬ъ (F Рѕи ╬Е')
          {╬ћ = MIP.D K РЄљ (I РіЌ MIP.D H) Рѕи []}
          {f = body} {g = MIP.h H} {h = MIP.g K})))
      stepFg :
        cut (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) (РіЌR IR ax) fgTensor refl
        РЅЌ fgPlain
      stepFg =
        (((~ (РЅАtoРЅЌ (cutРіЌRРіЌLcases++ (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) []
          {f = IR} {g = ax} {h = fgI})))
          Рѕў
          cut-congРѓѓ (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) refl
            (cutaxA-left (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I Рѕи []) fgI refl))
          Рѕў
          РЅАtoРЅЌ (cutРЄљL-cases++РѓЂ ╬ћРѓЂ ╬ЊРѓЂ {╬Џ = []}
            {╬ЏРѓЂ = MIP.D H Рѕи []}
            {f = IR} {g = IL {╬Њ = ╬ћРѓЂ} {╬ћ = []} f} {h = MIP.g H}))
        Рѕў РЄљL (cutIRIL ╬ћРѓЂ [] {g = f}) refl
      stepBody :
        cut (B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) (РіЌR IR ax) rhsBody refl
        РЅЌ assocBody
      stepBody =
        РЅАtoРЅЌ (cutРЄљL-cases++РѓЂ (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) []
          {╬Џ = []} {╬ЏРѓЂ = []}
          {f = РіЌR IR ax} {g = fgTensor} {h = MIP.h K})
        Рѕў РЄљL stepFg refl
      bodyCut :
        cut [] rhsH body refl РЅЌ assocBody
      bodyCut =
        (РЅАtoРЅЌ (cutРЄљRРЄљLcases++ [] [] (MIP.D H Рѕи [])
          {╬ћ = B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ}
          {f = rhsBody} {g = РіЌR IR ax} {h = ax})
        Рѕў
        cut-congРѓѓ (B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ) refl
          (cutaxA-right rhsBody))
        Рѕў stepBody
      eqh :
        cut [] rhsH t refl РЅЌ lhsH
      eqh =
        (РЄљR bodyCut
        Рѕў
        РЄљR (~ (РЄљLРЄљL-assoc {╬ЊРѓђ = ╬ЊРѓЂ} {╬ЊРѓЂ = []}
          {╬ћ = ╬ћРѓЂ} {╬ЏРѓђ = MIP.D H Рѕи []} {╬ЏРѓЂ = []}
          {A = A} {A' = A'} {B = B} {B' = B'}
          {f = f} {g = MIP.g H} {h = MIP.h K})))
        Рѕў
        (~ (РЄљLРЄљR {╬Њ = B РЄљ A Рѕи ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ} {╬Џ = []}
          {A = A'} {B = B'} {A' = MIP.D H} {B' = MIP.D K}
          {f = f} {g = innerH}))
  in intrpРЅЌ (РєюРѕи (t , eqg , eqh) refl)
... | G Рѕи ╬Е'''' rewrite ++?-injРѓѓ ╬ћРѓЂ ╬Е'''' (F Рѕи ╬Е') G |
                         ++?-injРѓѓ (╬ЊРѓЂ ++ B' Рѕи G Рѕи ╬Е'''') ╬Е' ╬ъ F =
  let H = mip (╬ЊРѓЂ ++ B' Рѕи G Рѕи ╬Е'''') (F Рѕи ╬Е') [] g refl
      K = mip ╬Њ (B Рѕи []) ╬ъ h refl
      innerH =
        РЄљL {╬Њ = []}
          {╬ћ = ╬ЊРѓЂ ++ B' Рѕи G Рѕи ╬Е'''' ++ MIP.D H Рѕи []}
          {╬Џ = []} {A = A} {B = B}
          (MIP.g H) (MIP.h K)
  in intrpРЅЌ
    (h~
      (РЄљLРЄљR {╬Њ = B РЄљ A Рѕи ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ} {╬Џ = G Рѕи ╬Е''''}
        {A = A'} {B = B'} {A' = MIP.D H} {B' = MIP.D K}
        {f = f} {g = innerH}
      Рѕў
      РЄљR
        (РЄљLРЄљL-assoc {╬ЊРѓђ = ╬ЊРѓЂ} {╬ЊРѓЂ = []}
          {╬ћ = ╬ћРѓЂ} {╬ЏРѓђ = G Рѕи ╬Е'''' ++ MIP.D H Рѕи []}
          {╬ЏРѓЂ = []}
          {A = A} {A' = A'} {B = B} {B' = B'}
          {f = f} {g = MIP.g H} {h = MIP.h K})))
mipРЅЌРЄљLРЄљL-assoc ╬Њ (.(B РЄљ A) Рѕи ╬ћ) .(F Рѕи ╬Е' ++ ╬ъ)
  {╬ЊРѓЂ} {.(╬Њ)} {╬ћРѓЂ} {╬ЏРѓЂ} {╬ъ} {A} {B} {A'} {B'} {C} {f} {g} {h} eq
  | injРѓЂ (╬ћ , eq1 , eq2)
  | injРѓѓ ([] , refl , refl)
  | injРѓѓ (F , ╬Е' , eq3 , refl)
  | injРѓЂ (╬Е'' , eq4 , eq5)
  | injРѓѓ (G , ╬Е''' , eq6 , eq7) with injРѕи eq7
mipРЅЌРЄљLРЄљL-assoc ╬Њ (.(B РЄљ A) Рѕи .(╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬Е'')) .(F Рѕи ╬Е''' ++ ╬ЏРѓЂ ++ ╬ъ)
  {╬ЊРѓЂ} {.(╬Њ)} {.(╬Е'' ++ F Рѕи ╬Е''')} {╬ЏРѓЂ} {╬ъ} {A} {B} {A'} {B'} {C} {f} {g} {h} refl
  | injРѓЂ (.(╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬Е'') , refl , refl)
  | injРѓѓ ([] , refl , refl)
  | injРѓѓ (F , .(╬Е''' ++ ╬ЏРѓЂ) , refl , refl)
  | injРѓЂ (╬Е'' , refl , refl)
  | injРѓѓ (.F , ╬Е''' , refl , refl)
  | refl , refl
  rewrite cases++-injРѓЂ (╬Њ ++ B РЄљ A Рѕи ╬ЊРѓЂ) ╬Е'' (F Рѕи ╬Е''' ++ ╬ЏРѓЂ ++ ╬ъ) (B' РЄљ A') |
          cases++-injРѓѓ (B РЄљ A Рѕи ╬ЊРѓЂ) ╬Њ ╬Е'' (B' РЄљ A') |
          ++?-injРѓѓ ╬Е'' ╬Е''' (╬ЏРѓЂ ++ ╬ъ) F |
          cases++-injРѓЂ ╬Њ (╬ЊРѓЂ ++ B' Рѕи []) (╬ЏРѓЂ ++ ╬ъ) (B РЄљ A) |
          cases++-injРѓѓ [] ╬Њ (╬ЊРѓЂ ++ B' Рѕи []) (B РЄљ A) |
          ++?-injРѓѓ (╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬Е'') (╬Е''' ++ ╬ЏРѓЂ) ╬ъ F
  with ╬ЏРѓЂ
... | [] rewrite ++?-injРѓЂ [] (╬ЊРѓЂ ++ B' Рѕи []) ╬ъ |
                 cases++-injРѓЂ ╬ЊРѓЂ (╬Е'' ++ F Рѕи ╬Е''') [] (B' РЄљ A') |
                 cases++-injРѓЂ ╬ЊРѓЂ ╬Е'' (F Рѕи ╬Е''') (B' РЄљ A') |
                 ++?-injРѓЂ [] (╬Е'' ++ F Рѕи ╬Е''') [] |
                 ++?-injРѓЂ (F Рѕи ╬Е''') ╬Е'' [] =
  let Fm = mip ╬Е'' (F Рѕи ╬Е''') [] f refl
      H = mip (╬ЊРѓЂ ++ B' Рѕи []) [] [] g refl
      K = mip ╬Њ (B Рѕи []) ╬ъ h refl
      ╬Њo = ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬Е''
      body =
        РЄљL {╬Њ = ╬ЊРѓЂ} {╬ћ = ╬Е'' ++ MIP.D Fm Рѕи []}
          {╬Џ = MIP.D H Рѕи []}
          (MIP.g Fm) (MIP.g H)
      eqbody :
        РЄљL {╬Њ = ╬ЊРѓЂ} {╬ћ = ╬Е'' ++ MIP.D Fm Рѕи []} {╬Џ = []}
          (MIP.g Fm) g
        РЅЌ cut ╬Њo (РіЌR ax (MIP.h H)) (РіЌL {╬Њo} {[]} body) refl
      eqbody =
        (((РЄљL {╬Њ = ╬ЊРѓЂ} refl (~ (cutIRIL (╬ЊРѓЂ ++ B' Рѕи []) [] {g = g}))
          Рѕў (~ (РЅАtoРЅЌ (cutРЄљL-cases++-commРѓЂ ╬ЊРѓЂ {╬ЊРѓЂ = []}
            {╬ћ = ╬Е'' ++ MIP.D Fm Рѕи []} {╬Џ = []}
            {f = MIP.h H} {g = MIP.g Fm} {h = MIP.g H}))))
          Рѕў (~ (cutaxA-left ╬Њo
            (cut (╬Њo ++ MIP.D Fm Рѕи []) (MIP.h H) body refl) refl)))
          Рѕў (РЅАtoРЅЌ (cutРіЌRРіЌLcases++ ╬Њo []
            {f = ax} {g = MIP.h H} {h = body})))
      unitN :
        _~_ {╬Њ = ╬Њo} {╬ћ = F Рѕи ╬Е'''} {╬Џ = []} {C = A}
          (intrp (MIP.D Fm РіЌ MIP.D H)
            (РіЌL {╬Њo} {[]} body)
            (РіЌR (MIP.h Fm) (MIP.h H)))
          (intrp (MIP.D Fm)
            (РЄљL {╬Њ = ╬ЊРѓЂ} {╬ћ = ╬Е'' ++ MIP.D Fm Рѕи []} {╬Џ = []}
              (MIP.g Fm) g)
            (MIP.h Fm))
      unitN = РєюРѕи (РіЌR ax (MIP.h H) , eqbody , refl) refl
  in intrpРЅЌ
    (~-trans
      (h~
        (РЄљR
          (РЄљLРЄљL-assoc {╬ЊРѓђ = ╬ЊРѓЂ} {╬ЊРѓЂ = []}
            {╬ћ = ╬Е'' ++ MIP.D Fm Рѕи []} {╬ЏРѓђ = []} {╬ЏРѓЂ = []}
            {A = A} {A' = A'} {B = B} {B' = B'}
            {f = MIP.g Fm} {g = g} {h = MIP.h K})))
      (~-sym
        (РЄљL~РЄљ {╬Њ = ╬Њ} {╬ћРѓђ = ╬Њo} {╬ћРѓЂ = F Рѕи ╬Е'''}
          {╬ЏРѓђ = []} {╬ЏРѓЂ = ╬ъ} {A = A} {B = B} {C = C}
          unitN refl)))
... | L Рѕи ╬ЏРѓЂ' rewrite ++?-injРѓѓ (╬ЊРѓЂ ++ B' Рѕи []) ╬ЏРѓЂ' ╬ъ L |
                         cases++-injРѓЂ ╬ЊРѓЂ (╬Е'' ++ F Рѕи ╬Е''' ++ L Рѕи ╬ЏРѓЂ') [] (B' РЄљ A') |
                         cases++-injРѓЂ ╬ЊРѓЂ ╬Е'' (F Рѕи ╬Е''' ++ L Рѕи ╬ЏРѓЂ') (B' РЄљ A') |
                         ++?-injРѓЂ (L Рѕи ╬ЏРѓЂ') (╬Е'' ++ F Рѕи ╬Е''') [] |
                         ++?-injРѓЂ (F Рѕи ╬Е''') ╬Е'' (L Рѕи ╬ЏРѓЂ') =
  intrpРЅЌ (РєЮРѕи (t , eqg , eqh) refl)
  where
    Fm = mip ╬Е'' (F Рѕи ╬Е''') [] f refl
    Gm = mip (╬ЊРѓЂ ++ B' Рѕи []) (L Рѕи ╬ЏРѓЂ') [] g refl
    K = mip ╬Њ (B Рѕи []) ╬ъ h refl
    q : ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи
        MIP.D Fm Рѕи MIP.D Gm Рѕи [] Ріб MIP.D K
    q =
      РЄљL {╬Њ = []} {╬ћ = MIP.D Fm Рѕи []}
        {╬Џ = MIP.D Gm Рѕи []}
        ax
        (РЄљL {╬Њ = []} {╬ћ = MIP.D Gm Рѕи []} {╬Џ = []}
          ax ax)
    body : ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи
           MIP.D Fm РіЌ MIP.D Gm Рѕи [] Ріб MIP.D K
    body =
      РіЌL {╬Њ = ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи []}
        {╬ћ = []} q
    t : ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи [] Ріб
        MIP.D K РЄљ (MIP.D Fm РіЌ MIP.D Gm)
    t = РЄљR body
    stepQ :
      cut ╬Њ q (MIP.g K) refl
      РЅЌ
      РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D Fm Рѕи []}
        {╬Џ = MIP.D Gm Рѕи ╬ъ}
        ax
        (РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D Gm Рѕи []} {╬Џ = ╬ъ}
          ax (MIP.g K))
    stepQ =
      cutРЄљLРЅЌ ╬Њ ax (РЄљL {╬Њ = []} {╬ћ = MIP.D Gm Рѕи []} {╬Џ = []} ax ax)
        (MIP.g K) refl
      Рѕў
      РЄљL refl
        (cutРЄљLРЅЌ ╬Њ ax ax (MIP.g K) refl
        Рѕў РЄљL refl (cutaxA-left ╬Њ (MIP.g K) refl))
    stepBody :
      cut ╬Њ body (MIP.g K) refl
      РЅЌ
      РіЌL {╬Њ = ╬Њ ++ ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи []}
        {╬ћ = ╬ъ}
        (РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D Fm Рѕи []}
          {╬Џ = MIP.D Gm Рѕи ╬ъ}
          ax
          (РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D Gm Рѕи []} {╬Џ = ╬ъ}
            ax (MIP.g K)))
    stepBody =
      cutРіЌLРЅЌ ╬Њ (((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи []) []
        q (MIP.g K) refl
      Рѕў РіЌL {╬Њ = ╬Њ ++ ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи []}
          {╬ћ = ╬ъ}
          stepQ
    afterG :
      ╬Њ ++ ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи
      MIP.D Fm Рѕи L Рѕи ╬ЏРѓЂ' ++ ╬ъ Ріб C
    afterG =
      РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D Fm Рѕи []} {╬Џ = L Рѕи ╬ЏРѓЂ' ++ ╬ъ}
        ax
        (РЄљL {╬Њ = ╬Њ} {╬ћ = L Рѕи ╬ЏРѓЂ'} {╬Џ = ╬ъ}
          (MIP.h Gm) (MIP.g K))
    stepG :
      cut (╬Њ ++ ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи
            MIP.D Fm Рѕи [])
        (MIP.h Gm)
        (РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D Fm Рѕи []}
          {╬Џ = MIP.D Gm Рѕи ╬ъ}
