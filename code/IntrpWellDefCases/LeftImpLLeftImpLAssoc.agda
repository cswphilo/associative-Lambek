            {f = MIP.h H} {g = MIP.g Fm} {h = MIP.g H}))))
          Рѕў (~ (cutaxA-left ╬Њo
            (cut (╬Њo ++ MIP.D Fm Рѕи []) (MIP.h H) body refl) refl)))
          Рѕў (РЅАtoРЅЌ (cutРіЌRРіЌLcases++ ╬Њo []
