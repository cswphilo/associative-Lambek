  .(E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ ╬Е'''') .(F Рѕи ╬Е'' ++ ╬ъ)
