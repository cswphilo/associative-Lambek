      rhsBody =
        РЄљL {╬Њ = E Рѕи ╬Е'}
          {╬ћ = ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I РіЌ MIP.D H Рѕи []}
          {╬Џ = []} {A = A} {B = B}
          fgTensor (MIP.h K)
      assocBody : E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ MIP.D H Рѕи [] Ріб MIP.D K
      assocBody =
        РЄљL {╬Њ = E Рѕи ╬Е'}
          {╬ћ = ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ MIP.D H Рѕи []}
          {╬Џ = []} {A = A} {B = B}
          fgPlain (MIP.h K)
      lhsH =
        РЄљL {╬Њ = E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ} {╬Џ = []}
          f
          (РЄљR {╬Њ = E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ ++ B' Рѕи []}
            {A = MIP.D H}
            innerH)
      rhsH =
        РЄљR {╬Њ = E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ}
