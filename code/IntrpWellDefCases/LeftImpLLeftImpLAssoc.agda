    stepG =
      РЅАtoРЅЌ (cutРЄљL-cases++-commРѓЂ ╬Њ {╬ЊРѓЂ = []}
        {╬ћ = MIP.D Fm Рѕи []} {╬Џ = ╬ъ}
        {f = MIP.h Gm} {g = ax}
        {h = РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D Gm Рѕи []} {╬Џ = ╬ъ}
          ax (MIP.g K)})
      Рѕў
      РЄљL refl
        (РЅАtoРЅЌ (cutРЄљL-cases++РѓЂ [] ╬Њ {╬Џ = []} {╬ЏРѓЂ = ╬ъ}
          {╬Е = L Рѕи ╬ЏРѓЂ'}
          {f = MIP.h Gm} {g = ax} {h = MIP.g K}))
    stepF :
      cut (╬Њ ++ ((MIP.D K РЄљ MIP.D Gm) РЄљ MIP.D Fm) Рѕи [])
        (MIP.h Fm) afterG refl
      РЅЌ
      РЄљL {╬Њ = ╬Њ} {╬ћ = F Рѕи ╬Е'''} {╬Џ = L Рѕи ╬ЏРѓЂ' ++ ╬ъ}
        (MIP.h Fm)
        (РЄљL {╬Њ = ╬Њ} {╬ћ = L Рѕи ╬ЏРѓЂ'} {╬Џ = ╬ъ}
