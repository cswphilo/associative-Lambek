    stepF =
      РЅАtoРЅЌ (cutРЄљL-cases++РѓЂ [] ╬Њ {╬Џ = []}
        {╬ЏРѓЂ = L Рѕи ╬ЏРѓЂ' ++ ╬ъ} {╬Е = F Рѕи ╬Е'''}
        {f = MIP.h Fm} {g = ax}
        {h = РЄљL {╬Њ = ╬Њ} {╬ћ = L Рѕи ╬ЏРѓЂ'} {╬Џ = ╬ъ}
          (MIP.h Gm) (MIP.g K)})
