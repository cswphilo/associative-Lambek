      t : (MIP.D K РЄљ (I РіЌ MIP.D H)) Рѕи [] Ріб MIP.D K РЄљ MIP.D H
      t =
        РЄљR {╬Њ = (MIP.D K РЄљ (I РіЌ MIP.D H)) Рѕи []}
          {A = MIP.D H}
          body
      lhsG = РЄљL {╬Њ = ╬Њ} {╬ћ = F Рѕи ╬Е''} {╬Џ = ╬ъ}
        (MIP.h H) (MIP.g K)
      rhsG = РЄљL {╬Њ = ╬Њ} {╬ћ = F Рѕи ╬Е''} {╬Џ = ╬ъ}
        (РіЌR IR (MIP.h H)) (MIP.g K)
      midG :
        ╬Њ ++ MIP.D K РЄљ (I РіЌ MIP.D H) Рѕи MIP.D H Рѕи ╬ъ Ріб C
      midG = РЄљL {╬Њ = ╬Њ} {╬ћ = MIP.D H Рѕи []} {╬Џ = ╬ъ}
        {A = I РіЌ MIP.D H} {B = MIP.D K}
        (РіЌR IR ax) (MIP.g K)
      innerH : E Рѕи ╬Е' ++ B РЄљ A Рѕи ╬ЊРѓЂ ++ B' Рѕи MIP.D H Рѕи [] Ріб MIP.D K
      innerH =
        РЄљL {╬Њ = E Рѕи ╬Е'} {╬ћ = ╬ЊРѓЂ ++ B' Рѕи MIP.D H Рѕи []} {╬Џ = []}
          {A = A} {B = B}
          (MIP.g H) (MIP.h K)
      fgI : ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I Рѕи MIP.D H Рѕи [] Ріб A
      fgI =
        РЄљL {╬Њ = ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ ++ I Рѕи []} {╬Џ = MIP.D H Рѕи []}
          (IL {╬Њ = ╬ћРѓЂ} {╬ћ = []} f) (MIP.g H)
      fgTensor : ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ I РіЌ MIP.D H Рѕи [] Ріб A
      fgTensor = РіЌL {╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ} {[]} fgI
      fgPlain : ╬ЊРѓЂ ++ B' РЄљ A' Рѕи ╬ћРѓЂ ++ MIP.D H Рѕи [] Ріб A
      fgPlain =
        РЄљL {╬Њ = ╬ЊРѓЂ} {╬ћ = ╬ћРѓЂ} {╬Џ = MIP.D H Рѕи []}
          f (MIP.g H)
