{-# OPTIONS --rewriting #-}

module SeqCalc where

-- open import Fma
open import Data.List
open import Relation.Binary.PropositionalEquality hiding (_вү—_; [_])
open import Utilities

postulate At : Set

infix 22 _вҮ’_  _вҠ—_
--  _вҲЁ_ _вҲ§_



-- Formulae

data Fma : Set where
  at : At вҶ’ Fma
  I : Fma
  _вҠ—_ : Fma вҶ’ Fma вҶ’ Fma
  _вҮ’_ : Fma вҶ’ Fma вҶ’ Fma
  

Cxt : Set
Cxt = List Fma

infix 4 _вҠў_

data _вҠў_ : Cxt вҶ’ Fma вҶ’ Set where

  ax : вҲҖ {A}
    вҶ’ A вҲ· [] вҠў A
  
  IR : [] вҠў I

  IL : вҲҖ {О“ О” C}
    вҶ’ О“ ++ О” вҠў C
    вҶ’ О“ ++ I вҲ· О” вҠў C

  вҠ—R : вҲҖ {О“ О” A B}
    вҶ’ О“ вҠў A вҶ’ О” вҠў B
    вҶ’ О“ ++ О” вҠў A вҠ— B

  вҠ—L : вҲҖ {О“ О” A B C}
    вҶ’ О“ ++ A вҲ· B вҲ· О” вҠў C
    вҶ’ О“ ++ A вҠ— B вҲ· О” вҠў C

  вҮ’R : вҲҖ {О“ A B}
    вҶ’ A вҲ· О“ вҠў B
    вҶ’ О“ вҠў A вҮ’ B

  вҮ’L : вҲҖ {О“ О” Оӣ A B C}
    вҶ’ О” вҠў A вҶ’ О“ ++ B вҲ· Оӣ вҠў C
    вҶ’ О“ ++ О” ++ A вҮ’ B вҲ· Оӣ вҠў C


subst-cxt : вҲҖ {О“ О” C} вҶ’ О“ вүЎ О”
  вҶ’ О“ вҠў C вҶ’ О” вҠў C
subst-cxt refl f = f  

subst-succ : вҲҖ {О“ C D} вҶ’ C вүЎ D
  вҶ’ О“ вҠў C вҶ’ О“ вҠў D
subst-succ refl f = f 

-- axA : {A : Fma} вҶ’ A вҲ· [] вҠў A
-- axA {at x} = ax
-- axA {I} = IL {[]} IR
-- axA {A вҠ— AвӮҒ} = вҠ—L {[]} (вҠ—R axA axA)
-- axA {A вҮ’ AвӮҒ} = вҮ’R (вҮ’L {[]} axA axA)
-- axA {A вҮҗ AвӮҒ} = вҮҗR (вҮҗL {[]} axA axA)

-- Equivalence of derivations of product-free L

data _вү—_ : {О“ : Cxt} {A : Fma} вҶ’ О“ вҠў A вҶ’ О“ вҠў A вҶ’ Set where
-- equivalence relation
  refl : вҲҖ{О“ A} {f : О“ вҠў A} вҶ’ f вү— f
  ~_ : вҲҖ{О“ A} {f g : О“ вҠў A} вҶ’ f вү— g вҶ’ g вү— f
  _вҲҳ_ : вҲҖ{О“ A} {f g h : О“ вҠў A} вҶ’ f вү— g вҶ’ g вү— h вҶ’ f вү— h

-- congruence
  IL : вҲҖ {О“ О” C}
    вҶ’ {f g : О“ ++ О” вҠў C}
    вҶ’ f вү— g
    вҶ’ IL {О“} {О”} f вү— IL g
  вҮ’R : вҲҖ{О“ A B}
    вҶ’ {f g : A вҲ· О“ вҠў B} 
    вҶ’ f вү— g
    вҶ’ вҮ’R f вү— вҮ’R g
  вҮ’L : вҲҖ{О“ О” Оӣ A B C}
    вҶ’ {f f' : О” вҠў A} {g g' : О“ ++ B вҲ· Оӣ  вҠў C}
    вҶ’ f вү— f' вҶ’ g вү— g'
    вҶ’ вҮ’L f g вү— вҮ’L f' g'
  вҠ—R : вҲҖ {О“ О” A B}
    вҶ’ {f f' : О“ вҠў A} {g g' : О” вҠў B}
    вҶ’ f вү— f' вҶ’ g вү— g'
    вҶ’ вҠ—R f g вү— вҠ—R f' g'
  вҠ—L : вҲҖ {О“ О” A B C}
    вҶ’ {f g : О“ ++ A вҲ· B вҲ· О” вҠў C}
    вҶ’ f вү— g
    вҶ’ вҠ—L f вү— вҠ—L g

-- -- permutative conversions
  вҮ’LвҮ’R : вҲҖ{О“ О” Оӣ A B A' B'}
    вҶ’ {f : О” вҠў A} {g : A' вҲ· О“ ++ B вҲ· Оӣ вҠў B'}
    вҶ’ вҮ’L f (вҮ’R g) вү— вҮ’R (вҮ’L f g)
  вҠ—LвҮ’R : вҲҖ{О“ О” A B A' B'} 
    вҶ’ {f : A' вҲ· О“ ++ A вҲ· B вҲ· О” вҠў B'}
    вҶ’ вҠ—L (вҮ’R f) вү— вҮ’R (вҠ—L {_ вҲ· _} f)
  ILвҮ’R : вҲҖ{О“ О” A' B'} 
    вҶ’ {f : A' вҲ· О“ ++ О” вҠў B'}
    вҶ’ IL {О“} {О”} (вҮ’R f) вү— вҮ’R (IL {_ вҲ· _} f)
  вҮ’LвҠ—RвӮҒ : вҲҖ{О“ О” Оӣ О© A B A' B'} 
    вҶ’ {f : О” вҠў A} {g : О“ ++ B вҲ· Оӣ вҠў A'}
    вҶ’ {h : О© вҠў B'}
    вҶ’ вҮ’L f (вҠ—R g h) вү— вҠ—R (вҮ’L f g) h
  вҮ’LвҠ—RвӮӮ : вҲҖ{О“ О” Оӣ О© A B A' B'} 
    вҶ’ {f : О” вҠў A} {g : О© вҠў A'}
    вҶ’ {h : О“ ++ B вҲ· Оӣ вҠў B'}
    вҶ’ вҮ’L {О© ++ О“} f (вҠ—R g h) вү— вҠ—R g (вҮ’L f h)
  вҠ—LвҠ—RвӮҒ : вҲҖ{О“ О” Оӣ A B A' B'}
    вҶ’ {f : О“ ++ A вҲ· B вҲ· О” вҠў A'}
    вҶ’ {g : Оӣ вҠў B'}
    вҶ’ вҠ—L (вҠ—R f g) вү— вҠ—R (вҠ—L f) g
  вҠ—LвҠ—RвӮӮ : вҲҖ{О“ О” Оӣ A B A' B'}
    вҶ’ {f : О“ вҠў A'}
    вҶ’ {g : О” ++ A вҲ· B вҲ· Оӣ вҠў B'}
    вҶ’ вҠ—L {О“ ++ О”} (вҠ—R f g) вү— вҠ—R f (вҠ—L g)
  ILвҠ—RвӮҒ : вҲҖ{О“ О” Оӣ A' B'}
    вҶ’ {f : О“ ++ О” вҠў A'}
    вҶ’ {g : Оӣ вҠў B'}
    вҶ’ IL (вҠ—R f g) вү— вҠ—R (IL {О“} {О”} f) g
  ILвҠ—RвӮӮ : вҲҖ{О“ О” Оӣ A' B'}
    вҶ’ {f : О“ вҠў A'}
    вҶ’ {g : О” ++ Оӣ вҠў B'}
    вҶ’ IL {О“ ++ О”} (вҠ—R f g) вү— вҠ—R f (IL {О”} {Оӣ} g)
  вҠ—LвҠ—L : вҲҖ {О“ О” Оӣ A B A' B' C} 
    вҶ’ {f : О“ ++ A вҲ· B вҲ· О” ++ A' вҲ· B' вҲ· Оӣ вҠў C}
    вҶ’ вҠ—L {О“ ++ A вҠ— B вҲ· О”} (вҠ—L f) вү— вҠ—L (вҠ—L {О“ ++ A вҲ· B вҲ· О”} f)
  ILIL : вҲҖ {О“ О” Оӣ C} 
    вҶ’ {f : О“ ++ О” ++ Оӣ вҠў C}
    вҶ’ IL {О“ ++ I вҲ· О”} {Оӣ} (IL f) вү— IL (IL {О“ ++ О”} f)
  
  ILвҠ—L-commвӮҒ : вҲҖ {О“ О” Оӣ A B C}
    вҶ’ {f : О“ ++ О” ++ A вҲ· B вҲ· Оӣ вҠў C}
    вҶ’ IL (вҠ—L {О“ ++ О”} f) вү— вҠ—L {О“ ++ I вҲ· О”} (IL f)

  ILвҠ—L-commвӮӮ : вҲҖ {О“ О” Оӣ A B C}
    вҶ’ {f : О“ ++ A вҲ· B вҲ· О” ++ Оӣ вҠў C}
    вҶ’ IL {О“ ++ A вҠ— B вҲ· О”} {Оӣ} (вҠ—L f) вү— вҠ—L (IL {О“ ++ A вҲ· B вҲ· О”} f)

  вҠ—LвҮ’L-assoc : вҲҖ{О“ О”вӮҖ О”вӮҒ Оӣ A B A' B' C}
    вҶ’ {f : О”вӮҖ ++ A' вҲ· B' вҲ· О”вӮҒ вҠў A} {g : О“ ++ B вҲ· Оӣ вҠў C}
    вҶ’ вҠ—L {О“ ++ О”вӮҖ} (вҮ’L f g) вү— вҮ’L (вҠ—L f) g
  вҠ—LвҮ’L-commвӮҒ : вҲҖ{О“ О” Оӣ О© A B A' B' C} 
    вҶ’ {f : О” вҠў A} {g : О“ ++ A' вҲ· B' вҲ· Оӣ ++ B вҲ· О© вҠў C}
    вҶ’ вҠ—L (вҮ’L {О“ ++ A' вҲ· B' вҲ· Оӣ} f g) вү— вҮ’L {О“ ++ A' вҠ— B' вҲ· Оӣ} f (вҠ—L g) 
  вҠ—LвҮ’L-commвӮӮ : вҲҖ{О“ О” Оӣ О© A B A' B' C} 
    вҶ’ {f : О” вҠў A} {g : О“ ++ B вҲ· Оӣ ++ A' вҲ· B' вҲ· О© вҠў C}
    вҶ’ вҠ—L {О“ ++ О” ++ A вҮ’ B вҲ· Оӣ} (вҮ’L f g) вү— вҮ’L f (вҠ—L {О“ ++ B вҲ· Оӣ} g) 

  ILвҮ’L-assoc : вҲҖ{О“ О”вӮҖ О”вӮҒ Оӣ A B C}
    вҶ’ {f : О”вӮҖ ++ О”вӮҒ вҠў A} {g : О“ ++ B вҲ· Оӣ вҠў C}
    вҶ’ IL {О“ ++ О”вӮҖ} (вҮ’L f g) вү— вҮ’L (IL {О”вӮҖ} {О”вӮҒ} f) g
  ILвҮ’L-commвӮҒ : вҲҖ{О“ О” Оӣ О© A B C} 
    вҶ’ {f : О” вҠў A} {g : О“ ++ Оӣ ++ B вҲ· О© вҠў C}
    вҶ’ IL (вҮ’L {О“ ++ Оӣ} f g) вү— вҮ’L {О“ ++ I вҲ· Оӣ} f (IL g) 
  ILвҮ’L-commвӮӮ : вҲҖ{О“ О” Оӣ О© A B C} 
    вҶ’ {f : О” вҠў A} {g : О“ ++ B вҲ· Оӣ ++ О© вҠў C}
    вҶ’ IL {О“ ++ О” ++ A вҮ’ B вҲ· Оӣ} (вҮ’L f g) вү— вҮ’L f (IL {О“ ++ B вҲ· Оӣ} {О©} g) 

  вҮ’LвҮ’L-assoc : вҲҖ{О“вӮҖ О“вӮҒ О” ОӣвӮҖ ОӣвӮҒ A B A' B' C}
    вҶ’ {f : О” вҠў A'}
    вҶ’ {g : О“вӮҖ ++ B' вҲ· ОӣвӮҖ вҠў A} {h : О“вӮҒ ++ B вҲ· ОӣвӮҒ вҠў C}
    вҶ’ вҮ’L {О“вӮҒ ++ О“вӮҖ} f (вҮ’L g h) вү— вҮ’L (вҮ’L f g) h
  вҮ’LвҮ’L-comm : вҲҖ{О“ О”вӮҖ О”вӮҒ Оӣ Оһ A B A' B' C} 
    вҶ’ {f : О”вӮҖ вҠў A} {f' : О”вӮҒ вҠў A'}
    вҶ’ {g : О“ ++ B вҲ· Оӣ ++ B' вҲ· Оһ вҠў C}
    вҶ’ вҮ’L f (вҮ’L {О“ ++ B вҲ· Оӣ} f' g) вү— вҮ’L {О“ ++ О”вӮҖ ++ A вҮ’ B вҲ· Оӣ} f' (вҮ’L f g)

вүЎtoвү— : вҲҖ{T C}
  вҶ’ {f g : T вҠў C}
  вҶ’ f вүЎ g
  вҶ’ f вү— g
вүЎtoвү— refl = refl
 
     